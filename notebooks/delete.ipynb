   "source": [
    "import os\n",
    "import re\n",
    "import pandas as pd\n",
    "from bs4 import BeautifulSoup\n",
    "from IPython.display import display\n",
    "\n",
    "# Définir les chemins\n",
    "RAW_PATH = \"data/raw\"\n",
    "PROCESSED_PATH = \"data/processed\"\n",
    "\n",
    "# Créer le dossier processed s'il n'existe pas\n",
    "os.makedirs(PROCESSED_PATH, exist_ok=True)\n",
    "\n",
    "# Fonction de nettoyage complet\n",
    "def clean_text(text):\n",
    "    if not isinstance(text, str):\n",
    "        return \"\"\n",
    "    \n",
    "    # 1️ Supprimer les balises HTML\n",
    "    text = BeautifulSoup(text, \"html.parser\").get_text()\n",
    "\n",
    "    # 2️ Supprimer les URLs\n",
    "    text = re.sub(r\"http\\S+|www\\S+|https\\S+\", \"\", text)\n",
    "\n",
    "    # 3️ Supprimer les caractères spéciaux\n",
    "    text = re.sub(r\"[^a-zA-Z0-9\\s.,!?']\", \" \", text)\n",
    "\n",
    "    # 4️ Supprimer les espaces multiples\n",
    "    text = re.sub(r\"\\s+\", \" \", text).strip()\n",
    "\n",
    "    # 5️ Mise en minuscules\n",
    "    text = text.lower()\n",
    "\n",
    "    return text\n",
    "\n",
    "# Lister tous les CSV dans data/raw\n",
    "csv_files = [f for f in os.listdir(RAW_PATH) if f.endswith(\".csv\")]\n",
    "\n",
    "for file_name in csv_files:\n",
    "    file_path = os.path.join(RAW_PATH, file_name)\n",
    "    print(f\"\\n Traitement du fichier : {file_name}\")\n",
    "\n",
    "    # Charger le CSV\n",
    "    df = pd.read_csv(file_path)\n",
    "    print(f\"Taille initiale : {df.shape}\")\n",
    "    print(\"Aperçu avant nettoyage :\")\n",
    "    display(df.head(2))\n",
    "\n",
    "    # Nettoyage de base\n",
    "    df = df.drop_duplicates().fillna(\"\")\n",
    "\n",
    "    # Nettoyage du texte\n",
    "    if \"text\" in df.columns:\n",
    "        df[\"clean_text\"] = df[\"text\"].apply(clean_text)\n",
    "    elif \"content\" in df.columns:\n",
    "        df[\"clean_text\"] = df[\"content\"].apply(clean_text)\n",
    "    else:\n",
    "        print(\" Aucune colonne 'text' ou 'content' trouvée !\")\n",
    "\n",
    "    # Enregistrement\n",
